{
    "name": "dnadesign/silverstripe-populate",
    "description": "Populate your database through YAML files",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "yaml",
        "fixture",
        "populate",
        "mock",
        "faker"
    ],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Will Rossiter",
            "email": "will@fullscreen.io"
        }
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6.0",
        "silverstripe/versioned": "^3.0"
    },
    "require-dev": {
        "silverstripe/recipe-testing": "^4.0",
        "squizlabs/php_codesniffer": "^3.0",
        "cambis/silverstan": "dev-main",
        "phpstan/extension-installer": "1.4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "DNADesign\\Populate\\": "src/",
            "DNADesign\\Populate\\Tests\\": "tests/php/"
        }
    },
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-main": "4.0.x-dev"
        },
        "project-files-installed": [
            "behat.yml",
            "phpunit.xml.dist"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "silverstripe/recipe-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist",
        "test": "phpunit",
        "phpstan": "phpstan analyse src tests --level max --memory-limit=1G",
        "phpstan:fix": "phpstan analyse src tests --level max --fix --memory-limit=1G"
    }
}
